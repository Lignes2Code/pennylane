               // Mise à jour de la sélection dans la partie repliée sur Entrée ou Espace
               si ToucheEnfoncée(0x0D,vrai) _ou_  ToucheEnfoncée(0x20,Vrai) ALORS
               	// Si la liste est fermée
               	si pas gbListeDéroulanteOuverte ALORS
               		// Dérouler la liste des pays
               		ComboOuvre(MoiMême)
               		ExécuteTraitement(MoiMême,trtOuvertureCombo)	
               	sinon
               		// Exécuter la sélection
               		ExécuteTraitement(MoiMême,trtFermetureCombo)	
               	FIN
               FIN
              type : 65792
        -
          name : SAI_Téléphone
          identifier : 0x29f0c16f02343ac2
          internal_properties : 
          properties :
           x : 52
           y : 1
           width : 179
           height : 52
           accelerator_key : 65535
           tab_order : 1
          style : {}
          type : 2
          code_elements :
           type_code : 3
           p_codes :
            -
              code : |1+
               // Version 1
               // Description 
               // Gestion d'une fiche de contact
               // Photo modifiable au clic
               // Vérification d’email
               // Gestion des numéros de téléphone internationaux
               // Affichage de carte Google (ou autre) pour localiser l’adresse
               // Assistance à la saisie du Code Postal (français)
               
               // Fonctionnement : 
               // Une combo présente les préfixes téléphoniques internationaux
               // Il est possible de réaliser une saisie directe du pays ou de l'indicatif
               // Le formatage du numéro peut être réalisé selon le pays
               
               // Adaptation : 
               // Pour les pays ayant le même indicatif, il est possible de forcer le pays proposé par défaut 
               // (géré dans l'exemple pour les Etats-Unis). Par défaut, le premier pays trouvé avec l'indicatif est sélectionné. 
              type : 14
            -
              code : |1-
               
               // Retire les espaces inutiles en début et fin de numéro de téléphone
               moimeme = sansespace(moimeme)
              type : 16
            -
              type : 276
              enabled : false
            -
              type : 277
              enabled : false
            -
              type : 278
              enabled : false
            -
              type : 338
              enabled : false
            -
              type : 339
              enabled : false
            -
              code : |1-
               soit sNumeroTéléphone = sansespace(moimeme)
               // Si le champ est vide, ne rien faire
               SI sNumeroTéléphone = "" ALORS RETOUR
               // Si le contenu ne débute pas par un "+" (indicatif), ne rien faire
               SI sNumeroTéléphone[[1]] <> "+" ALORS RETOUR
               // Si le contenu comporte un espace, ne rien faire
               SI sNumeroTéléphone [=] " " ALORS RETOUR
               // Retire le + du préfixe
               soit nPrefixeSaisie = sNumeroTéléphone[[2 A]]
               
               // Trouve une nation à partir du préfixe, puis trouve l'indice dans le champ Combo à partir de la nation
               si gtaPrefixeVersCodeISO2[nPrefixeSaisie]..Existe _et_ gtaCodeISO2VersIndiceCombo[gtaPrefixeVersCodeISO2[nPrefixeSaisie]]..Existe ALORS
               	// Force la sélection de l'indicatif
               	COMBO_Indicatif	= gtaCodeISO2VersIndiceCombo[gtaPrefixeVersCodeISO2[nPrefixeSaisie]]	
               	// Applique la sélection du pays
               	ExécuteTraitement(COMBO_Indicatif,trtSélection)			
               FIN
              type : 17
       type : 40
       code_elements :
        type_code : 34
        p_codes :
         -
           code : |1+
            // Pays proposés pour leur indicatif
            gtabListePays est un tableau de Pays = PaysListe()
            
            // Contexte d'UI
            gbListeDéroulanteOuverte est un booléen = faux
            gnIndicePrécédentPays est un entier = -1
            
            // Tri alphabétique
            procédure interne triAlphabetiquePays(pays1 est un pays, pays2 est un pays)
            	RENVOYER ChaîneCompare(pays1.nom,pays2.nom)
            FIN
            TableauTrie(gtabListePays,ttFonction,triAlphabetiquePays)
            
            // Mise en cache de la position dans le champ Combo de chaque pays à partir de leur Nation
            gtaCodeISO2VersIndiceCombo est un tableau associatif d'entiers
            pour tout paysCourant,nIndicePays de gtabListePays
            	gtaCodeISO2VersIndiceCombo[paysCourant.CodeISO2] = nIndicePays
            FIN
            
            // Permet de choisir la nation à sélectionner lorsque son indicatif est saisi
            gtaPrefixeVersCodeISO2 est un tableau associatif de chaine 
            POUR TOUT paysCourant,nIndicePays de gtabListePays
            	si gtaPrefixeVersCodeISO2[paysCourant.PréfixeNuméroDeTéléphone]..Existe continue
            	gtaPrefixeVersCodeISO2[paysCourant.PréfixeNuméroDeTéléphone] = paysCourant.CodeISO2
            FIN
            
            // Couleur pour les indicatifs
            couleurIndicatif est une couleur = COMBO_Indicatif..Couleur	
            
            // Reprend la même couleur que le texte, en plus léger
            couleurIndicatif..Luminosité += couleurIndicatif..Luminosité>175 ? -75 SINON 75
            
            // Préférences sur les ambiguïtés de préfixe
            // Permet de choisir la nation à sélectionner lorsque son indicatif est saisi alors que plusieurs nations partagent le même préfixe
            local
            // Ajoutez ici les autres cas d'un même indicatif partagé entre plusieurs pays dont vous souhaitez résoudre l’ambiguïté
            // sinon la première nation dans l'ordre alphabétique sera prise (mettre le nom ou le code ISO du pays)
            tabPaysFavorisPourPréfixe est un tableau de chaine = [ "US" , "Russie", "GB", "Réunion" ]
            pour TOUT sNomPaysOuCodeIso DE tabPaysFavorisPourPréfixe
            	// Récupère les informations du pays
            	paysFavoris est un pays = PaysRécupère(sNomPaysOuCodeIso)
            	// Ignore si hors combo
            	si pas gtaCodeISO2VersIndiceCombo[paysFavoris.CodeISO2] continue 
            	// Indique le pays comme étant le pays à sélectionner en cas de saisi de son indicatif (même si d'autres pays ont le même indicatif)
            	gtaPrefixeVersCodeISO2[paysFavoris.PréfixeNuméroDeTéléphone] = paysFavoris.CodeISO2
            FIN
            	
            
         -
           code : |1-
            
            // Initialise la saisie assistée de pays
            POUR nPaysCourant = 1 _a_ gtabListePays..Occurrence
            	// Ajoute ce pays
            	ListeAjoute(COMBO_Indicatif,FormateDrapeauPaysPrefixe(nPaysCourant)	)	
            FIN
            
            soit sCodeISOPaysDefaut = ""
            // Suggestion : pré remplir le pays selon la langue courante si cela correspond au cas le plus fréquent
            SELON Nation()
            	CAS nationFrançais
            		sCodeISOPaysDefaut = "FR"
            				
            	AUTRE CAS
            		sCodeISOPaysDefaut = ""
            FIN
            
            // Sélectionne la nation par défaut
            // ou la première de la liste si elle n'est pas trouvée 
            COMBO_Indicatif = (sCodeISOPaysDefaut<>"" _et_ gtaCodeISO2VersIndiceCombo[sCodeISOPaysDefaut]..Existe) ? gtaCodeISO2VersIndiceCombo[sCodeISOPaysDefaut] sinon 1
            
            // Applique la mise en forme sur la ligne sélectionnée
            ExécuteTraitement(COMBO_Indicatif,trtSélection)
           type : 14
         -
           code : |1-
            // Met à jour le numéro de téléphone
            SAI_Téléphone = moimeme
            // Et synchronise le préfixe
            ExécuteTraitement(SAI_Téléphone,trtModification)
           type : 43
         -
           code : |1-
            // Renvoie le numéro de téléphone
            renvoyer SAI_Téléphone
           type : 42
        procedures :
         -
           name : FormateDrapeauPaysPrefixe
           procedure_id : 1869206527847774961
           type_code : 14
           code : |1+
            // Résumé : <indiquez ici ce que fait la procédure>
            // Syntaxe :
            // FormateDrapeauPaysPrefixe ()
            //
            // Paramètres :
            //	Aucun
            // Valeur de retour :
            // 	Aucune
            //
            // Exemple :
            // Indiquez ici un exemple d'utilisation.
            //
            PROCEDURE FormateDrapeauPaysPrefixe(nIndicePays est un entier,bDrapeauSeul est un booléen = faux) : chaine
            
            // Indique le drapeaux et l'indice du pays
            retour =  glien(nIndicePays) + gImage(gtabListePays[nIndicePays]..Drapeau)
            
            // Ajoute éventuellement le nom du pays et l'indicatif téléphonique
            si pas bDrapeauSeul ALORS
            	paysCourant est un pays = gtabListePays[nIndicePays]	
            	retour = RETOUR + [" "] + paysCourant..Nom + "  " + gstylo(couleurIndicatif) + "+" + paysCourant..PréfixeNuméroDeTéléphone
            FIN
           type : 458752
