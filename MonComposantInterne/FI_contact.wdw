              type : 18
       type : 40
       code_elements :
        type_code : 34
        p_codes :
         -
           code : |1+
            // Version 1
            // Description 
            // Gestion d'une fiche de contact
            // Photo modifiable au clic
            // Vérification d’email
            // Gestion des numéros de téléphone internationaux
            // Affichage de carte Google (ou autre) pour localiser l’adresse
            // Assistance à la saisie du Code Postal (français)
            
            // Fonctionnement : 
            // La saisie d'un code postal propose les villes associées
            // La saisie partielle d'une ville propose les villes + code postal 
            // Remarque : La base de données est fournie sous forme d'un fichier CSV.
            
            STInfo est une structure 
            	// Pour plus d'informations voir https://www.data.gouv.fr/fr/datasets/base-officielle-des-codes-postaux-1/
            	Code_commune_INSEE est une chaine
            	//Nom de la commune en majuscule sans accent
            	Nom_commune       est une chaine
            	Code_postal       est une chaine
            	Libelle_acheminement  est une chaine	
            	//précision du lieu-dit associé ou du nom de la commune déléguée associée en majuscule sans accent
            	Ligne_5           est une chaine		
            	coordonnees_gps   est une chaine
            	
            	//contient en majuscule sans accent : nom de la commune et du lieu dit associé ou nom de la commune déléguée associée 
            	sNomPourRechercheEnMajuscule est une chaine
            fin
            
            gtabInfos est un tableau de STInfo
            gtabRésultatsComplet est un tableau de chaine 
            
            CONSTANTE
            	CSV_CodePostaux = <§R19f0c16f002f3ab2¤fr-FR¤CM\laposte_hexasmal\laposte_hexasmal.csv¤en-GB¤SMC\laposte_hexasmal\laposte_hexasmal.csv¤es-ES¤SMC\laposte_hexasmal\laposte_hexasmal.csv¤0§>
            FIN
         -
           code : |1-
            
           type : 14
        procedures :
         -
           name : MajRecherche
           internal_properties : HgAAAB4AAABSqY+8AGSGTX6MDEEyoIsUtgW+9YsZauneRLSqDmd8QQzuzWQmpSfEm012q+ZeW/2dag45BhwNvnc5LV+L6ogLi+zHMj+05Kqs/lB2eh616uzQnaP+jJ/YSnkred2b4f/GupMIu3u+bjMY+Bgfka4jKKMqbMdzS1SUF5QVIn7EusTEWxw=
           procedure_id : 1869206527847447218
           type_code : 14
           code : |1-
            // Résumé : <indiquez ici ce que fait la procédure>
            // Syntaxe :
            // MajRecherche ()
            //
            // Paramètres :
            //	Aucun
            // Valeur de retour :
            // 	Aucune
            //
            // Exemple :
            // Indiquez ici un exemple d'utilisation.
            //
            PROCEDURE MajRecherche(sCodePostalSaisi="",sVilleSaisie="")
            
            // Supprime les précédents résultats
            SaisieAssistéeSupprimeTout(SAI_Recherche)
            
            // Charge la base des codes postaux si ce n'est pas déjà fait
            ChargeInfoCPAuBesoin()
            
            // Pas de résultat en l'absence de saisie
            SI sCodePostalSaisi="" _ET_ sVilleSaisie="" ALORS
            	SaisieAssistéeFerme(SAI_Recherche)
            	RETOUR
            FIN
            
            // Mémorise et formate le paramètre de recherche : code postal ou commune
            soit sRecherche = sCodePostalSaisi
            soit bRechercheSelonCodePostal = sCodePostalSaisi<>""
            SI PAS bRechercheSelonCodePostal ALORS
            	// Formate le nom tel qu'il est présent dans 
            	sRecherche = FormateRecherche(Majuscule(sVilleSaisie).SansAccent().Remplace("'"," "))
            FIN
            
            // Tableau des résultats de recherche avec une comparaison en "commence par", voire "contient" pour les recherches de communes
            taBlindageAntiDoublon est un tableau associatif de chaînes
            tabRésultatsCommencerPar est un tableau de chaine 
            tabRésultatsContient est un tableau de chaine 
            tabRésultatsCedex est un tableau de chaine 
            tableausupprimetout(gtabRésultatsComplet)
            
            // Parcours de la base pour trouver les communes correspondant à la recherche
            POUR TOUT stElementRecherché de gtabInfos
            	bEstTrouveViaContient est un booléen = faux
            	SI ChercheCPVille(stElementRecherché,bEstTrouveViaContient) ALORS
            		// Utilise le code postal, le nom de la commune et le lieu-dit associé éventuel pour l'affichage dans l'assistance
            		sRésultat est une chaine = stElementRecherché.Code_postal+ " "+ stElementRecherché.Nom_commune + [" ("] + (stElementRecherché.Ligne_5 + [")"])
            		// Cas particuliers des villes avec arrondissements
            		soit sNomCommunePourCriterePoids = stElementRecherché.Nom_commune
            		SI Position(sNomCommunePourCriterePoids,["LYON "," MARSEILLE ", "PARIS "]) = 1 _ET_ EstNumérique(ExtraitChaîne(sNomCommunePourCriterePoids,2," ")) ALORS
            			sNomCommunePourCriterePoids = ExtraitChaîne(sNomCommunePourCriterePoids,rangPremier," ")
            		FIN
            		// Préfixe avec un poids pour la pertinence de la recherche comparé à la taille du nom de la commune
            		sRésultat = (bRechercheSelonCodePostal ? 1 SINON Arrondi(100 * (1 - (TailleCommune(sRecherche,sNomCommunePourCriterePoids) / Taille(sNomCommunePourCriterePoids))))) + " " + sRésultat
            		// Évite d'ajouter 2 résultats identiques
            		SI  taBlindageAntiDoublon[sRésultat]..Existe ALORS
            			CONTINUE 
            		FIN
            		taBlindageAntiDoublon[sRésultat] = Vrai		
            		// Ajoute le résultat dans le tableau des résultats qui sera trié en fin de parcours de la base
            		si Position(sRésultat," CEDEX")>0 ALORS
            			TableauAjoute(tabRésultatsCedex,sRésultat)			
            		sinon			
            		SI bEstTrouveViaContient ALORS
            			TableauAjoute(tabRésultatsContient,sRésultat)
            		SINON
            			TableauAjoute(tabRésultatsCommencerPar,sRésultat)
            		FIN
            	FIN
            FIN
            FIN
            	PROCÉDURE INTERNE ChercheCPVille(ElémentRecherché,bEstTrouveViaContient)
            	// Recherche du code postal
            	SI bRechercheSelonCodePostal ALORS
            		RENVOYER ElémentRecherché.Code_postal [= sRecherche 
            	FIN
            	// Recherche de la commune ou lieu dit selon la règle "commence par"
            	SI ElémentRecherché.sNomPourRechercheEnMajuscule [= sRecherche	 ALORS
            		RENVOYER Vrai
            	FIN
            	// Recherche selon la règle "contient"
            	bEstTrouveViaContient=(ElémentRecherché.sNomPourRechercheEnMajuscule [=] sRecherche	)
            	RENVOYER bEstTrouveViaContient
            	FIN	
            
            // Trie les résultats et les ajoute dans l'assistance
            tabRésultatsContient.Trie(tccSansAccent+tccSansCasse+tccSansEspace+tccSansEspaceIntérieur+tccSansPonctuationNiEspace+tccRespecteNumérique+tccOrdreLexicographique)
            tabRésultatsCommencerPar.Trie(tccSansAccent+tccSansCasse+tccSansEspace+tccSansEspaceIntérieur+tccSansPonctuationNiEspace+tccRespecteNumérique+tccOrdreLexicographique)
            tabRésultatsCedex.Trie(tccSansAccent+tccSansCasse+tccSansEspace+tccSansEspaceIntérieur+tccSansPonctuationNiEspace+tccRespecteNumérique+tccOrdreLexicographique)
            
            // Ajoute au tableau complet avec les résultats selon "commence par" en premier
            gtabRésultatsComplet.ajoute(tabRésultatsCommencerPar)
            gtabRésultatsComplet.ajoute(tabRésultatsContient)
            gtabRésultatsComplet.ajoute(tabRésultatsCedex)
            
            
            // Assistance inutile : aucun résultat, ou un seul résultat qui correspond déjà à la saisie
            SI gtabRésultatsComplet..Vide _ou_ (gtabRésultatsComplet..Occurrence=1 _ET_ gtabRésultatsComplet[1] = SAI_Code_postal + " " + SAI_Ville_Commune)
            	// Interdit la tabulation
            	SAI_Recherche..Visible = Faux
            	// Ferme l'assistance
            	SaisieAssistéeFerme(SAI_Recherche)		
            	RETOUR
            FIN	
            
            pour TOUT sRésultat DE gtabRésultatsComplet
            	// Ajoute le code postal et la ville (sans le préfixe de poids de la pertinence)
            	SaisieAssistéeAjoute(SAI_Recherche,sRésultat[[Position(sRésultat," ")+1 À]])
            FIN
            
            // Affiche l'assistance à la saisie
            SaisieAssistéeOuvre(SAI_Recherche)
            
            // Restaure l'ordre de tabulation
            SAI_Recherche..Visible = Vrai
           type : 458752
         -
           name : ChargeInfoCPAuBesoin
           procedure_id : 1869206527847512754
           type_code : 14
           code : |1-
            PROCEDURE ChargeInfoCPAuBesoin()
            
            // Inutile de le refaire si la base a déjà été chargée
            si gtabInfos..Occurrence>0 alors retour
            
            // Indique que la base est en cours de chargement
            ToastAffiche(<§R19f0c16f00323ab2¤fr-FR¤Chargement des codes postaux...¤en-GB¤Loading postal codes...¤es-ES¤Cargando códigos postales...¤0§>,toastLong)
            
            // Charge les données
            soit sContenu est une chaine  = fChargeTexte(CSV_CodePostaux)
            
            // Retire la 1ère ligne des titres :
            // Code_commune_INSEE;Nom_commune;Code_postal;Libelle_acheminement;Ligne_5;coordonnees_gps
            sContenu = sContenu[[Position(sContenu,RC)+Taille(RC) À]]
            
            // Renseigne les données dans le tableau
            CSVVersTableau(sContenu,gtabInfos,";")
            
            // Formate la chaîne à rechercher
            POUR TOUT stElementRecherché DE gtabInfos	
            	stElementRecherché.sNomPourRechercheEnMajuscule = FormateRecherche(stElementRecherché.Nom_commune) + [" "] + FormateRecherche(stElementRecherché.Ligne_5)	
            FIN
            
            fin:
            // Retire le toast de chargement
            ToastSupprimeTout()
           type : 458752
         -
           name : FormateRecherche
           procedure_id : 1869206527847643826
           type_code : 14
           code : |1+
            // Formate la chaîne pour faciliter les recherches
            PROCEDURE FormateRecherche(s)
            RENVOYER Remplace(s,"ST","SAINT").Remplace("STE","SAINTE") //rajouter des aides à la saisie
           type : 458752
        procedure_templates : []
        property_templates : []
     -
       name : SC_Telephone
       identifier : 0x29f0c16f02323ac2
       internal_properties : 
       properties :
        x : 92
        y : 181
        width : 231
        height : 59
        tab_order : 2
       style : {}
       controls :
        -
          name : COMBO_Indicatif
          identifier : 0x29f0c16f02333ac2
          internal_properties : 
          properties :
           x : 3
           width : 44
           height : 53
           accelerator_key : 65535
           tab_order : 0
          style : {}
          dropdown :
           internal_properties : 
           properties :
            width : 300
           style :
            scrollbar :
             monochrome : 1
           type : 7
          type : 14
          code_elements :
           type_code : 23
           p_codes :
            -
              type : 35
              enabled : false
            -
              code : |1-
               
               // Dérouler la liste des pays au focus
               ComboOuvre(MoiMême)
               ExécuteTraitement(MoiMême,trtOuvertureCombo)	
              type : 15
            -
              code : |1+
               // Ignore si la liste déroulante est dépliée
               SI gbListeDéroulanteOuverte ALORS	
               	retour
               FIN
               
               // Ignore une sélection de la même ligne 
               si gnIndicePrécédentPays = MoiMême ALORS
               	retour
               FIN
               
               // Applique le masque correspondant
               SAI_Téléphone..MasqueSaisie	= MasqueNuméroDeTéléphone(gtabListePays[MoiMême],mtelAvecOuSansPréfixe)
               
               // Met à jour la partie repliée du champ Combo avec le drapeau seul si la liste déroulante est fermée
               MoiMême[MoiMême]			= FormateDrapeauPaysPrefixe(MoiMême,pas gbListeDéroulanteOuverte)
               MoiMême						= MoiMême
               
               // Indique la valeur courante dans la bulle 
               Moimeme..Bulle				= gtabListePays[MoiMême]..Nom + " (+" + gtabListePays[MoiMême]..PréfixeNuméroDeTéléphone+")"
               
               // Cas de changement d'indicatif
               si gnIndicePrécédentPays>-1 ALORS	
               	// Récupère l'indicatif de la précédente sélection (indice mémorisé dans gnIndicePrécédentPays)
               	sIndicatifPrécédent	est une chaîne	= gtabListePays[gnIndicePrécédentPays].PréfixeNuméroDeTéléphone
               	
               	// Récupère l'indicatif de la sélection courante
               	sIndicatifSélection	est une chaîne	= gtabListePays[MoiMême].PréfixeNuméroDeTéléphone
               	
               	// En cas de changement d'indicatif
               	si sIndicatifPrécédent<>sIndicatifSélection ALORS
               		
               		// Dans le numéro actuellement présent dans le champ, remplace l'ancien indicatif (s'il est présent) par le nouvel indicatif
               		SAI_Téléphone				= Remplace(SAI_Téléphone, "+"+sIndicatifPrécédent, "+"+sIndicatifSélection)
               		
               		// Si le numéro est vierge et que le pays a été changé pour un autre que celui par défaut, l'indicatif est rajouté
               		SI SAI_Téléphone="" _ou_ SAI_Téléphone="+" ALORS
               			SAI_Téléphone="+"+gtabListePays[MoiMême].PréfixeNuméroDeTéléphone + " "
               		FIN
               		
               		// Donne le focus à la saisie de numéro une fois l'indicatif choisi
               		DonneFocus(SAI_Téléphone)
               		// Se positionne à la fin de la saisie
               		SAI_Téléphone..Curseur = Taille(SAI_Téléphone) + 1
               	FIN
               FIN
               
               // Mémorise dans gnIndicePrécédentPays l'indice de la nouvelle sélection
               gnIndicePrécédentPays = MoiMême
              type : 33
            -
