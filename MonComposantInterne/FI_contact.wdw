           enabled : false
         -
           type : 339
           enabled : false
         -
           code : |1-
            SaisieAssistéeSupprimeTout(MoiMême)
            si MoiMême<>"" _et_ moimeme =] "@" ALORS
            	si SAI_Société<>"" ALORS
            		SaisieAssistéeAjoute(MoiMême,MoiMême + SAI_Société + ".com")	
            	FIN
            	SaisieAssistéeAjoute(MoiMême,moimeme + "gmail.com")
            	SaisieAssistéeAjoute(MoiMême,moimeme + "hotmail.com")
            	SaisieAssistéeAjoute(MoiMême,moimeme + "yahoo.com")
            	SaisieAssistéeOuvre(MoiMême)
            sinon
            	SaisieAssistéeFerme(MoiMême)
            FIN
