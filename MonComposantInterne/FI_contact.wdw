              enabled : false
            -
              type : 278
              enabled : false
            -
              type : 338
              enabled : false
            -
              type : 339
              enabled : false
            -
              code : |1-
               IMG_MarqueurGris..Visible=Vrai
               IMG_Marqueur..Visible=Faux
               
               // Lance la vérification à chaque frappe, dans un délai de 300ms relancé à chaque frappe
               Vérification()
               PROCÉDURE INTERNE Vérification() 	<délai=300ms, appels suivants=relancer>
               	// Exécute la vérification	
               	ExécuteTraitement(SAI_Adresse_postale,trtSortie)
               FIN	
              type : 17
        -
          name : IMG_Marqueur
          identifier : 0x29f0c16f02193a55
          internal_properties : 
          properties :
           x : 6
           y : 21
           width : 27
           height : 27
           visible : 0
           tool_tip : Afficher sur une carte
           cursor_id : 32649
           tab_stop : 0
           take_focus : 0
          style : {}
          type : 8
          code_elements :
           type_code : 8
           p_codes :
            -
              code : |1+
               
               // Crée le champ carte et le cache
               // Le champ sera affiché par un clic sur ce marqueur et la carte recouvrira les derniers champs du formulaire
               Moimeme..Note = <§R19f0c16f002d3a64¤fr-FR¤CARTE_Adresse¤en-GB¤MAP_Address¤es-ES¤MAP_Address¤0§> + DonneGUID()
               CARTE_Adresse est un Champ <- ChampCrée(IMG_Marqueur..Note,typCarte)
               CARTE_Adresse..visible=faux
               CARTE_Adresse..Altitude=9999
               // Adapte la position du champ carte 
               CARTE_Adresse..X = SAI_Adresse_postale..X
               CARTE_Adresse..Y = SAI_Adresse_postale..Y	
               // Adapte la taille du champ carte selon les champs formulaire à recouvrir
               SurRedimensionnementAdapteCarte()
               MaFenêtre..Traitement[trtChangeTaille] += SurRedimensionnementAdapteCarte
               procédure interne SurRedimensionnementAdapteCarte()
               	CARTE_Adresse..Hauteur = SAI_Notes..Y + SAI_notes..Hauteur - SAI_Adresse_postale..Y
               	CARTE_Adresse..Largeur = SAI_Adresse_postale..Largeur	
               fin
              type : 14
            -
              code : |1-
               // Récupère le champ carte créé
               CARTE_Adresse est un Champ <- {IMG_Marqueur..Note,indChamp}
               
               // Affiche la carte au dessus du formulaire et masque le formulaire
               soit bAfficheCarte = GR_SOUSCARTE..Visible
               CARTE_Adresse..visible = bAfficheCarte
               GR_SOUSCARTE..visible = pas bAfficheCarte
               
               si bAfficheCarte ALORS	
               	// Utilisez dans le code de projet la fonction CarteLicenceGgl pour utiliser le champ carte https://doc.pcsoft.fr/1000021299
               	
               	// Masque les contrôles du champ carte et adapte le zoom s'il y a une adresse
               	CarteExécuteJS(CARTE_Adresse,<§R19f0c16f002e3a64¤fr-FR¤CarteRécupèreObjetJS().setOptions({zoomControl:false,disableDefaultUI:true,zoom: ¤en-GB¤MapGetJOSNObject().setOptions({zoomControl:false,disableDefaultUI:true,zoom: ¤es-ES¤MapGetJOSNObject().setOptions({zoomControl:false,disableDefaultUI:true,zoom: ¤0§> + (SAI_Adresse_postale="" ? (SAI_Ville_Commune="" ? 4 sinon 10) sinon 16)  + ",mapTypeControl:false,streetViewControl:false,scaleControl :false});")		
               	DonneFocus(CARTE_Adresse)
               FIN
              type : 18
