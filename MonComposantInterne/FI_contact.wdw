        -
          name : SAI_Adresse_postale
          identifier : 0x29f0c16f01fa39c8
          internal_properties : 
          properties :
           x : 40
           width : 526
           height : 59
           anchor : 8
           accelerator_key : 65535
           tab_order : 0
           group : GR_SOUSCARTE
          style : {}
          type : 2
          code_elements :
           type_code : 3
           p_codes :
            -
              code : |1+
               
               // Récupère le champ carte créé
               CARTE_Adresse est un Champ <- {IMG_Marqueur..Note,indChamp}
               
               // Recherche l'adresse sur la carte
               adrSaisie est une adresse
               adrSaisie.Rue = SAI_Adresse_postale
               adrSaisie.CodePostal = SAI_Code_postal
               adrSaisie.Ville = SAI_Ville_Commune
               adrSaisie.Région = SAI_Province
               adrSaisie.Pays = SAI_Pays
               CarteSupprimeTout(CARTE_Adresse)
               
               // Positionne la carte sur l'adresse renseignée et appelle bCallbackCarte en indiquant si la carte a pu se positionner sur cette adresse
               CarteAffichePosition(CARTE_Adresse,adrSaisie,bCallbackCarte) 
               SI ErreurDétectée ALORS
               	bCallbackCarte(Faux)
               FIN
               
               //Place le marqueur sur la carte 
               PROCÉDURE INTERNE bCallbackCarte(bChangementEffectué) 
               	// Si la carte affiche bien l'adresse saisie le marqueur gris devient rouge
               	IMG_MarqueurGris..Visible=PAS bChangementEffectué
               	IMG_Marqueur..Visible=bChangementEffectué
               	// En cas de réussite la carte affiche un marqueur sur l'adresse trouvée	
               	SI bChangementEffectué ALORS
               		MaPosition est une géoPosition
               		MaPosition = CarteRécupèrePosition(CARTE_Adresse)
               		CarteAjouteMarqueur(CARTE_Adresse,MaPosition)
               	FIN
               FIN
               
               
              type : 16
            -
