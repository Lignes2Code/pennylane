     -
       name : SAI_E_mail
       identifier : 0x29f0c16f01f43989
       internal_properties : 
       properties :
        x : 72
        y : 13
        width : 231
        height : 59
        accelerator_key : 65535
        tab_order : 0
       style : {}
       type : 2
       code_elements :
        type_code : 3
        p_codes :
         -
           code : |1+
            si moimeme..note = "" ALORS
            	MoiMême..Note = MoiMême..couleur
            FIN
            
            si EmailVérifieAdresse(moimeme,emailValideSyntaxeStrict) <> emailAdresseValide ALORS
            	moimeme..Couleur = RougeClair
            sinon
            	MoiMême..Couleur = MoiMême..Note
            FIN
           type : 16
         -
           type : 276
           enabled : false
         -
           type : 277
           enabled : false
         -
           type : 278
           enabled : false
         -
           type : 338
           enabled : false
         -
           type : 339
           enabled : false
         -
           code : |1-
            SaisieAssistéeSupprimeTout(MoiMême)
            si MoiMême<>"" _et_ moimeme =] "@" ALORS
            	si SAI_Société<>"" ALORS
            		SaisieAssistéeAjoute(MoiMême,MoiMême + SAI_Société + ".com")	
            	FIN
            	SaisieAssistéeAjoute(MoiMême,moimeme + "gmail.com")
            	SaisieAssistéeAjoute(MoiMême,moimeme + "hotmail.com")
            	SaisieAssistéeAjoute(MoiMême,moimeme + "yahoo.com")
            	SaisieAssistéeOuvre(MoiMême)
            sinon
            	SaisieAssistéeFerme(MoiMême)
            FIN
           type : 17
