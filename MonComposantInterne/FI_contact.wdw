         -
           code : |1+
            si moimeme..note = "" ALORS
            	MoiMême..Note = MoiMême..couleur
            FIN
            
            si EmailVérifieAdresse(moimeme,emailValideSyntaxeStrict) <> emailAdresseValide ALORS
            	moimeme..Couleur = RougeClair
            sinon
            	MoiMême..Couleur = MoiMême..Note
            FIN
           type : 16
