     p_codes :
      -
        code : |1+
         PROCEDURE MaFenêtre()
         
         constante
         	CHEMIN_IMAGE_EN_COURS = "IMG-Chargement-01.svg"
         	CHEMIN_IMAGE_EST_VALIDE = "valide.png"
         	CHEMIN_IMAGE_EST_REFUSE= "refuser.png"
         	CHEMIN_IMAGE_EN_ATTENTE = "attente.png"
         fin
         
         
         
         
         
         etatsDetailsProvisionnings est un tableau de etatDetailProvisionning
         
         tokingProvisionning est un etatDetailProvisionning
         tokingProvisionning.detail = "Obtention du token Provisionning"
         tokingProvisionning.etat = etatProvisionning.en_attente
         
         userProvisionning est une etatDetailProvisionning
         userProvisionning.detail = " Création de l'utilisateur"
         userProvisionning.etat = etatProvisionning.en_cours
         
         entrepriseProvisionning est un etatDetailProvisionning
         entrepriseProvisionning.detail = "Creation de l'entreprise"
         entrepriseProvisionning.etat = etatProvisionning.est_valide
         
         ZR_provisionning.InsèreFI(1,FI_provisioning,tokingProvisionning)
         ZR_provisionning.InsèreFI(2,FI_provisioning,userProvisionning)
         ZR_provisionning.InsèreFI(3,FI_provisioning,entrepriseProvisionning)
         DemandeMiseAJourUI()
         
         
      -
        code : |1+
         
         
        type : 14
