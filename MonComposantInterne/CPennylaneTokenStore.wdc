     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure Effacer()
      TokenAcces.Valeur						= ""
      TokenAcces.DateExpiration				= "00000000000000"
      TokenRafraichissement.Valeur			= ""
      TokenRafraichissement.DateExpiration	= "00000000000000"
      oConfig.Sauvegarder()
     type : 458752
