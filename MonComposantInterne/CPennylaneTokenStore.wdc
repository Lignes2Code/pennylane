   -
     name : Stocker
     procedure_id : 1867675595345387130
     type_code : 12
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure Stocker(sAcces est une Chaîne, sRefresh est une Chaîne, nExpiresIn est un Entier)
      TokenAcces.Valeur						= sAcces
      TokenAcces.Type							= "Bearer"
      TokenAcces.DateExpiration				= DateHeureSys() + (nExpiresIn / 100)
      // nExpiresIn fourni par l'API en secondes → conversion en DateHeure
      
      TokenRafraichissement.Valeur			= sRefresh
      TokenRafraichissement.Type				= "Bearer"
      TokenRafraichissement.DateExpiration	= DateHeureSys() + (90 * 24 * 3600 / 100)
      // Refresh token valide 90 jours
      
      // Persister dans la config (sérialisé/chiffré)
      oConfig.Sauvegarder()
      
     type : 458752
   -
     name : Charger
     procedure_id : 1867675732784438419
     type_code : 12
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure Charger(): Booléen
      RETOUR oConfig.Charger(oConfig.CheminFichier)
      
     type : 458752
