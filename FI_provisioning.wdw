    code_elements :
     type_code : 70
     p_codes :
      -
        code : |1-
         PROCEDURE MaFenêtre(etatDetailProvisionning est un etatDetailProvisionning)
         CheminImageEtat est une chaine
         SELON etatDetailProvisionning.etat
         	CAS en_cours
         		CheminImageEtat = fRepDonnées()+ fSep() + CHEMIN_IMAGE_EN_COURS
         		IMG_etat.Animation = vrai
         
         
         	CAS en_attente
         		CheminImageEtat = fRepDonnées()+ fSep() + CHEMIN_IMAGE_EN_ATTENTE
         		IMG_etat.Animation = faux
         
         	CAS est_refuse
         		CheminImageEtat = fRepDonnées()+ fSep() + CHEMIN_IMAGE_EST_REFUSE
         		IMG_etat.Animation = Faux
         
         	CAS est_valide
         		CheminImageEtat = fRepDonnées()+ fSep() + CHEMIN_IMAGE_EST_VALIDE
         		IMG_etat.Animation = Faux
         
         FIN
         
         LIB_Libellé = etatDetailProvisionning.detail
         IMG_etat = CheminImageEtat
      -
        code : |1+
         
         
        type : 14
