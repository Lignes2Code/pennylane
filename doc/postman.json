		{
			"name": "Sandbox - Company API - Import a customer e-invoice",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{companyAPIToken_Test}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "multipart/form-data"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"description": "(Required) The invoice file to be imported.\nMust be an e-invoice format.\n",
							"type": "file",
							"src": []
						},
						{
							"key": "invoice_options",
							"value": "{\"customer_id\":1234567,\"invoice_lines\":[{\"e_invoice_line_id\":\"1\",\"ledger_account_id\":1234567},{\"e_invoice_line_id\":\"2\",\"ledger_account_id\":1234567}]}",
							"description": "(Optional) Optional JSON payload to enrich the imported customer invoice. Invoice line e_invoice_line_id must match Factur-X BT-126 (LineID).",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{baseURL_Test}}/api/external/v2/customer_invoices/e_invoices/imports",
					"host": [
						"{{baseURL_Test}}"
					],
					"path": [
						"api",
						"external",
						"v2",
						"customer_invoices",
